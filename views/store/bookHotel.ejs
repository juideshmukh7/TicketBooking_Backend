            <div class="p-4">
              <h3 class="text-xl font-semibold text-gray-800 mb-2">Hotel Taj</h3>
              <p class="text-gray-600 mb-2"><i class="fas fa-map-marker-alt mr-2"></i>Mumbai</p>
              <div class="flex justify-between items-center mb-2">
                <span class="text-lg font-bold text-red-500">Rs 5000 / night</span>
